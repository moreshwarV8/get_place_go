# Copy this file to ".env" and fill in your own Supabase project's values.
# Find these in your Supabase dashboard → Project Settings → API.
# These are PUBLIC, browser-safe keys (the anon/publishable key is protected by Row Level Security).
# Server-only secrets (OPENROUTER_API_KEY, SCRAPEGRAPH_API_KEY, service role key) live in
# Supabase Edge Function secrets, NOT here.

VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-or-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"
